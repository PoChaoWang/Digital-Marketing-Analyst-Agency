{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/google-sheet-report.schema.json",
  "title": "Google Sheet Report Definition",
  "type": "object",
  "additionalProperties": false,
  "required": ["spreadsheet", "tabs"],
  "properties": {
    "spreadsheet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "mode"],
      "properties": {
        "title": { "type": "string" },
        "mode": { "type": "string", "enum": ["create", "update"] },
        "spreadsheet_id": { "type": "string" },
        "spreadsheet_url": { "type": "string" },
        "folder_id": { "type": "string" },
        "locale": { "type": "string" },
        "timezone": { "type": "string" },
        "currency": { "type": "string" }
      }
    },
    "tabs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "purpose", "source_section", "columns"],
        "properties": {
          "name": { "type": "string" },
          "purpose": { "type": "string" },
          "source_section": { "type": "string" },
          "columns": {
            "type": "array",
            "items": { "type": "string" }
          },
          "formatting": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "freeze_header": { "type": "boolean" },
              "apply_filter": { "type": "boolean" },
              "currency_columns": {
                "type": "array",
                "items": { "type": "string" }
              },
              "percent_columns": {
                "type": "array",
                "items": { "type": "string" }
              },
              "number_columns": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}

