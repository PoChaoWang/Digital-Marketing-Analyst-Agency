# --- System Layer (Tracked) ---
# Backlog capabilities and Mock MCP are part of the system logic
!modes/backlog/*
!test/mock-mcp/*

# --- User Layer (Ignored) ---
# Secrets and private credentials
.env
.env.*
!.env.example
config/*.json

# Account and Data Source configurations (User specific)
config/accounts.yml
config/data-sources.yml
profile/

# Data artifacts and exports
data/*
!data/.gitkeep
!data/README.md
test/public-data/*
!test/public-data/.gitkeep
reports/
exports/
output/*
!output/.gitkeep

# Temporary files and computation results
tmp/*
!tmp/.gitkeep
tmp/recipe-results/*
!tmp/recipe-results/.gitkeep

# --- Development & System (Ignored) ---
*.log
.DS_Store
.venv/
__pycache__/
*.pyc

# Personal notes and scratchpads
prompt.md
note.md
docs/DASHBOARD_ARCHITECTURE_PLAN.md

docs/MVP_VALIDATION_SUMMARY.md